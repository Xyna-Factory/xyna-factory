<DataType xmlns="http://www.gip.com/xyna/xdev/xfractmod" Version="1.8" TypeName="ExportSettings" TypePath="xmcp.factorymanager.xynaproperties" Label="Export Settings" IsAbstract="false">
  <Meta>
    <IsServiceGroupOnly>false</IsServiceGroupOnly>
  </Meta>
  <Data Label="Format" VariableName="format">
    <Meta>
      <Type>String</Type>
      <Documentation>The format of the export, one of: CSV, YAML</Documentation>
    </Meta>
  </Data>
  <Data Label="Filter" VariableName="filter">
    <Meta>
      <Type>String</Type>
      <Documentation>Filter string to be matched</Documentation>
    </Meta>
  </Data>
  <Data Label="Include Documentation" VariableName="includeDocumentation">
    <Meta>
      <Type>boolean</Type>
      <Documentation>Whether to include the documentation in all available languages</Documentation>
    </Meta>
  </Data>
</DataType>
