<project name="build" default="build" basedir=".">

    <!-- this is the absolute path to the root -->
    <pathconvert property="root.dir" >
        <path location="${basedir}/../../../../.."/>
    </pathconvert>

    <property name="sharedLib.folder.name" value="gitIntegrationScriptEntries" />
    <property name="sharedLib.name" value="gitIntegrationScriptEntries" />

    <import file="${root.dir}/installation/build/buildSharedLib.xml" />
	
    <target name="prepareLibs" description="Prepare Libs">
        <ant antfile="build.xml" target="build" inheritAll="false" dir="${basedir}/../../mdmimpl/FactoryObjectManagementImpl">
            <property name="target.dir" value="${basedir}/lib/" />
        </ant>
		
        <ant antfile="build.xml" target="build" inheritAll="false" dir="${basedir}/../../mdmimpl/WorkspaceObjectManagementImpl">
            <property name="target.dir" value="${basedir}/lib/" />
        </ant>
	</target>

</project>
