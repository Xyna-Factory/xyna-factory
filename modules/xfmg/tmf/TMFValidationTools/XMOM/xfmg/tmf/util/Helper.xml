<DataType xmlns="http://www.gip.com/xyna/xdev/xfractmod" IsAbstract="false" Label="Helper" TypeName="Helper" TypePath="xfmg.tmf.util" Version="1.8">
  <Meta>
    <IsServiceGroupOnly>true</IsServiceGroupOnly>
  </Meta>
  <Service Label="Helper" TypeName="Helper">
    <Operation IsStatic="true" Label="lexicopgraphic comparison" Name="lexicopgraphicComparison">
      <Input>
        <Data ID="1" Label="TextA" ReferenceName="Text" ReferencePath="base" VariableName="text1"/>
        <Data ID="2" Label="TextB" ReferenceName="Text" ReferencePath="base" VariableName="text2"/>
      </Input>
      <Output>
        <Data ID="3" Label="IntegerNumber" ReferenceName="IntegerNumber" ReferencePath="base.math" VariableName="integerNumber3"/>
      </Output>
      <SourceCode>
        <CodeSnippet Type="Java">return new IntegerNumber(text1.getText().compareTo(text2.getText()));</CodeSnippet>
      </SourceCode>
    </Operation>
  </Service>
</DataType>
