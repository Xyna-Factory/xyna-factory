      <SourceCode>
        <CodeSnippet Type="Java">
xmcp.oas.datatype.OASValidationResult result = new xmcp.oas.datatype.OASValidationResult();
result.setErrorMessages(new ArrayList&lt;String&gt;());
// validate ServiceTestStateType.value of type String
try {
    var validator_value = new com.gip.xyna.openapi.StringTypeValidator();
    validator_value.setName("Value");
    validator_value.setValue(getValue());
    validator_value.setAllowableValues("acknowledged", "rejected", "pending", "inProgress", "cancelled", "completed", "failed");
    result.getErrorMessages().addAll(validator_value.checkValid());
} catch (Exception e) {
    result.getErrorMessages().add("Error: could not validate ServiceTestStateType.value");
}

return result.getResult();
        </CodeSnippet>
