 <XynaCommandLineCommand>
  <CommandDefinition Name="modifykeypair" Groups="SSH Connection Management" Description="Changing the identity, priority, and type class of a key pair in the identity repository."/>
  <Argument Name="identity" Description="Name of the key pair."/>
  <Argument Name="new_identity" Description="New name of the key pair." Optional="true"/>
  <Argument Name="new_priority" Description="New priority of the key pair." Optional="true"/>
  <Argument Name="new_typeclass" Description="New typeclass of the key pair." Optional="true"/>
</XynaCommandLineCommand>
