--><DataType xmlns="http://www.gip.com/xyna/xdev/xfractmod" Version="1.8" TypeName="KeyInfoService" TypePath="xact.ssh" Label="Key Info Service" IsAbstract="false">
  <Meta>
    <IsServiceGroupOnly>true</IsServiceGroupOnly>
  </Meta>
  <Libraries>KeyInfoServiceImpl.jar</Libraries>
  <SharedLibraries>sshlibs</SharedLibraries>
  <Service Label="KeyInfo Service" TypeName="KeyInfoService">
    <Meta>
      <AdditionalDependencies>
      </AdditionalDependencies>
    </Meta>
    <Operation Label="get Key Info" Name="getKeyInfo" IsStatic="true">
      <Input>
        <Data ID="2" Label="base64KeyBlob" VariableName="text" ReferenceName="Text" ReferencePath="base">
        </Data>
      </Input>
      <Output>
        <Data ID="1" Label="Key Info" VariableName="keyInfo" ReferenceName="KeyInfo" ReferencePath="xact.ssh">
        </Data>
      </Output>
      <Meta>
        <Documentation>Uses a Base64 blob representation of an SSH Key to classify the key according to algorithm and bitlength and whether it is a private or public key.
This method needs to be ported into the SSH App.

Currently supports:
- OpenSSH Base64 formats
- RSA, DSA, ECDSA and ed25511 Algorithms</Documentation>
      </Meta>
      <SourceCode>
        <CodeSnippet Type="Java">return xact.ssh.KeyInfoServiceImpl.getKeyInfo(text);</CodeSnippet>
      </SourceCode>
    </Operation>
  </Service>
</DataType>
