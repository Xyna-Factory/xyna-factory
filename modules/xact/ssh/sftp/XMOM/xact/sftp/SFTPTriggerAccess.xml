--><DataType xmlns="http://www.gip.com/xyna/xdev/xfractmod" Label="SFTP Trigger Access" TypeName="SFTPTriggerAccess" TypePath="xact.sftp" Version="1.8">
  <Meta>
    <IsServiceGroupOnly>true</IsServiceGroupOnly>
  </Meta>
  <Libraries>SFTPTriggerAccessImpl.jar</Libraries>
  <Service Label="SFTP Trigger Access" TypeName="SFTPTriggerAccess">
    <Operation IsStatic="true" Label="add one time credentials" Name="addOneTimeCredentials">
      <Input>
        <Data Label="Username" ReferenceName="Username" ReferencePath="xact.sftp" VariableName="username"/>
        <Data Label="Password" ReferenceName="Password" ReferencePath="xact.sftp" VariableName="password"/>
        <Data Label="IP" ReferenceName="IP" ReferencePath="base" VariableName="iP"/>
        <Data Label="Port" ReferenceName="Port" ReferencePath="base" VariableName="port"/>
      </Input>
      <Output/>
      <Throws>
        <Exception Label="Server Exception" ReferenceName="XynaException" ReferencePath="core.exception" VariableName="xynaException"/>
        <Exception Label="One Time Credential Collision" ReferenceName="OneTimeCredentialCollision" ReferencePath="xact.sftp" VariableName="oneTimeCredentialCollision"/>
      </Throws>
      <SourceCode>
        <CodeSnippet Type="Java">xact.sftp.SFTPTriggerAccessImpl.addOneTimeCredentials(username, password, iP, port);</CodeSnippet>
      </SourceCode>
    </Operation>
  </Service>
</DataType>
