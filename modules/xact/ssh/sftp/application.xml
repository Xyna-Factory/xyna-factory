<Application applicationName="SFTPServer" comment="" factoryVersion="" versionName="2.0.0" xmlVersion="1.1">
  <ApplicationInfo>
    <Description Lang="DE">Erzeuge Dateien per Workflow ausgelöst durch SCP oder SFTP.</Description>
    <Description Lang="EN">Create files via Workflow triggered by SCP or SFTP.</Description>
    <RuntimeContextRequirements>
      <RuntimeContextRequirement>
        <ApplicationName>Base</ApplicationName>
        <VersionName>1.1.4</VersionName>
      </RuntimeContextRequirement>
      <RuntimeContextRequirement>
        <ApplicationName>SSHServer</ApplicationName>
        <VersionName>2.0.0</VersionName>
      </RuntimeContextRequirement>
    </RuntimeContextRequirements>
  </ApplicationInfo>
  <Filters>
    <Filter implicitDependency="true">
      <Name>SFTPFilter</Name>
      <JarFiles>SFTPFilter/SFTPFilter.jar:</JarFiles>
      <FqFilterClassname>com.gip.xyna.xact.filter.SFTPFilter</FqFilterClassname>
      <TriggerName>SSHTrigger</TriggerName>
      <SharedLibs/>
    </Filter>
  </Filters>
  <XMOMEntries>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.CacheParameter</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.Content</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.None</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.OneTimeCredentialCollision</FqName>
      <Type>EXCEPTION</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.Password</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.Path</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.SFTPTriggerAccess</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.SessionIsolated</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.SourceIP</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.Timed</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.Username</FqName>
      <Type>DATATYPE</Type>
    </XMOMEntry>
    <XMOMEntry implicitDependency="false">
      <FqName>xact.sftp.demo.ProcessSFTPRequest</FqName>
      <Type>WORKFLOW</Type>
    </XMOMEntry>
  </XMOMEntries>
</Application>
