<DataType xmlns="http://www.gip.com/xyna/xdev/xfractmod" IsAbstract="false" Label="HTTP Response Resolver" TypeName="HTTPResponseResolver" TypePath="xact.http" Version="1.8">
  <Meta>
    <IsServiceGroupOnly>true</IsServiceGroupOnly>
  </Meta>
  <Libraries>HTTPResponseResolverImpl.jar</Libraries>
  <Service Label="HTTP Response Resolver" TypeName="HTTPResponseResolver">
    <Operation IsStatic="true" Label="Resolve Response" Name="resolveResponse">
      <Input>
        <Data ID="1" Label="Document" ReferenceName="Document" ReferencePath="xact.templates" VariableName="document1"/>
        <Data ID="3" Label="Send Parameter" ReferenceName="SendParameter" ReferencePath="xact.http" VariableName="sendParameter3"/>
        <Data ID="6" Label="dir" VariableName="file6" ReferenceName="File" ReferencePath="base">
        </Data>
      </Input>
      <Output>
        <Data ID="2" Label="Document" ReferenceName="Document" ReferencePath="xact.templates" VariableName="document2"/>
        <Data ID="4" Label="Header" ReferenceName="Header" ReferencePath="xact.http" VariableName="header4"/>
        <Data ID="5" Label="HTTP Status Code" ReferenceName="HTTPStatusCode" ReferencePath="xact.http.enums.statuscode" VariableName="hTTPStatusCode5"/>
      </Output>
      <SourceCode>
        <CodeSnippet Type="Java">return xact.http.HTTPResponseResolverImpl.resolveResponse(document1, sendParameter3, file6);</CodeSnippet>
      </SourceCode>
    </Operation>
  </Service>
</DataType>
