<project name="projectmacros" basedir=".">

  <taskdef resource="net/sf/antcontrib/antlib.xml"/>
  
    <!-- ================================= 
         macro: load according to type
         ================================= -->
    <macrodef name="load-according-to-type">
        <attribute name="build.type"/>
        <sequential>
            <echo message="loading ant targets for type '@{build.type}'" level="debug" />
            <switch value="@{build.type}">
                <case value="application">
                    <import file="${root.dir}/installation/build/buildApplication.xml" />
                </case>
                <case value="service">
                    <import file="${root.dir}/installation/build/buildService.xml" />
                </case>
                <case value="trigger">
                    <import file="${root.dir}/installation/build/buildTrigger.xml" />
                </case>
                <case value="filter">
                    <import file="${root.dir}/installation/build/buildFilter.xml" />
                </case>
                <case value="sharedlib">
                    <import file="${root.dir}/installation/build/buildSharedLib.xml" />
                </case>
                <default>
                    <echo message="Not loading additional files for type '@{build.type}'" level="debug" />
                </default>
            </switch>
        </sequential>
    </macrodef>


    <load-according-to-type build.type="${build.type}" />

</project>
